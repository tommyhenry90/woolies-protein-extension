# Chrome Web Store API credentials for the GitHub Actions release workflow.
# These are also stored as GitHub repository secrets (Settings → Secrets and
# variables → Actions). Local copy here is just for convenience if you ever
# want to run the upload manually with chrome-webstore-upload-cli.
#
# Copy this file to .env and fill in real values. NEVER commit .env.

CWS_EXTENSION_ID=
CWS_CLIENT_ID=
CWS_CLIENT_SECRET=
CWS_REFRESH_TOKEN=
