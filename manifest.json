{
  "manifest_version": 3,
  "name": "Woolies Protein Tags",
  "description": "Shows protein content per 100g on every product tile across woolworths.com.au.",
  "version": "0.2.0",
  "permissions": ["storage"],
  "host_permissions": [
    "https://www.woolworths.com.au/*"
  ],
  "action": {
    "default_title": "Woolies Protein Tags",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.woolworths.com.au/*"],
      "js": ["inject.js"],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": false
    },
    {
      "matches": ["https://www.woolworths.com.au/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_start",
      "all_frames": false
    }
  ]
}
