{
  "manifest_version": 3,
  "name": "Woolies Protein Tags",
  "description": "Rates every Woolworths product by protein per 100 kcal — colour-coded pill on each tile plus nutrition details on hover.",
  "version": "1.0.1",
  "permissions": ["storage"],
  "action": {
    "default_title": "Woolies Protein Tags",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://www.woolworths.com.au/*"],
      "js": ["inject.js"],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": false
    },
    {
      "matches": ["https://www.woolworths.com.au/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_start",
      "all_frames": false
    }
  ]
}
